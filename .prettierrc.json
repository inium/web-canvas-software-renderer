{
  "singleQuote": false,
  "semi": true,
  "trailingComma": "all",
  "tabWidth": 4,
  "printWidth": 80,
  "endOfLine": "lf",
  "overrides": [
    {
      "files": "**/*.html",
      "options": {
        "tabWidth": 2,
        "printWidth": 140
      }
    },
    {
      "files": "**/*.json",
      "options": {
        "tabWidth": 2
      }
    },
    {
      "files": "./src/main.ts",
      "options": {
        "printWidth": 120
      }
    }
  ]
}
